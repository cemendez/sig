        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "checkJs": false,
        "allowJs": true,
        "jsx": "preserve"
    },
    "exclude": ["node_modules", "dist"]
}
