<div id="sidebar-wrapper" class="sidebar-wrapper">
    <div id="sidebar-backdrop" class="sidebar-backdrop"></div>
    <aside id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <span class="logo">🗺️</span>
                <span class="brand-title">Geoportal GovTech</span>
            </div>
            <button id="close-sidebar" class="close-btn" aria-label="Cerrar"
                >✕</button
            >
        </div>

        <div class="sidebar-content">
            <h2>Capas de Información</h2>

            <div class="layer-group">
                <h3>🏥 Infraestructura de Salud</h3>
                <label class="layer-item">
                    <input
                        type="checkbox"
                        class="layer-toggle"
                        data-layer="hospitales"
                        checked
                    />
                    Zonas de Influencia (2km)
                </label>
            </div>

            <div class="layer-group">
                <h3>🚧 Obras Públicas</h3>
                <label class="layer-item">
                    <input
                        type="checkbox"
                        class="layer-toggle"
                        data-layer="obras"
                        data-status="dentro_presupuesto"
                        checked
                    />
                    <span class="dot dot-ok"></span> Obras en Regla
                </label>
                <label class="layer-item">
                    <input
                        type="checkbox"
                        class="layer-toggle"
                        data-layer="obras"
                        data-status="sobrecosto"
                        checked
                    />
                    <span class="dot dot-bad"></span> Obras con Sobrecosto
                </label>
            </div>
        </div>
    </aside>
</div>

<style>
    .sidebar-wrapper {
        display: contents;
    }

    /* Mobile First - Default styles */
    .sidebar-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(4px);
        z-index: 20;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    :global(.sidebar-active) .sidebar-backdrop {
        opacity: 1;
        visibility: visible;
    }

    .sidebar {
        position: fixed;
        top: var(--header-height); /* Empezar debajo del header */
        left: 0;
        height: calc(100dvh - var(--header-height));
        width: 280px;
        max-width: 85vw;
        background: white;
        z-index: 25;
        transform: translateX(-100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    :global(.sidebar-active) .sidebar {
        transform: translateX(0);
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.2rem 1rem;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .brand-title {
        font-weight: 700;
        color: #1e293b;
        font-size: 0.95rem;
    }

    .close-btn {
        background: #f1f5f9;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        color: #64748b;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: all 0.2s;
    }
    .close-btn:hover {
        background: #e2e8f0;
        color: #0f172a;
    }

    .sidebar-content {
        padding: 1.5rem 1rem;
        flex-grow: 1;
        overflow-y: auto;
    }

    h2 {
        font-size: 0.8rem;
        color: #94a3b8;
        text-transform: uppercase;
        margin: 0 0 1rem 0;
        letter-spacing: 1px;
        font-weight: 700;
    }

    .layer-group {
        margin-bottom: 2rem;
    }
    .layer-group h3 {
        font-size: 0.9rem;
        color: #1e293b;
        font-weight: 600;
        margin-bottom: 0.8rem;
    }

    .layer-item {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 0.6rem;
        font-size: 0.9rem;
        cursor: pointer;
        color: #475569;
        padding: 10px;
        border-radius: 8px;
        transition: all 0.2s;
        border: 1px solid transparent;
    }
    .layer-item:hover {
        background: #f1f5f9;
        color: #1e293b;
        border-color: #e2e8f0;
    }
    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        border: 2px solid white;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1);
    }
    .dot-ok {
        background-color: #10b981;
    }
    .dot-bad {
        background-color: #ef4444;
    }

    /* Desktop Adjustments - min-width 769px */
    @media (min-width: 769px) {
        .sidebar {
            position: static;
            transform: none;
            width: 300px;
            max-width: none;
            height: 100%;
            box-shadow: none;
            border-right: 1px solid #e2e8f0;
        }
        .sidebar-header {
            display: none;
        }
        .sidebar-backdrop {
            display: none !important;
        }
        .sidebar-content {
            padding: 2rem 1.5rem;
        }
        h2 {
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
        }
        :global(.sidebar-active) .sidebar {
            transform: none;
        }
    }
</style>

<script>
    // @ts-nocheck

    // 1. Manejo de Toggles de Capas
    document.querySelectorAll(".layer-toggle").forEach((checkbox) => {
        checkbox.addEventListener("change", (e) => {
            const target = e.target;
            const eventData = {
                layer: target.dataset.layer,
                status: target.dataset.status || null,
                visible: target.checked,
            };
            document.dispatchEvent(
                new CustomEvent("filterLayer", { detail: eventData }),
            );
        });
    });

    // 2. Lógica del Drawer
    const body = document.body;
    const backdrop = document.getElementById("sidebar-backdrop");
    const closeBtn = document.getElementById("close-sidebar");

    const toggleSidebar = () => {
        body.classList.toggle("sidebar-active");
    };

    const closeSidebar = () => {
        body.classList.remove("sidebar-active");
    };

    document.addEventListener("toggleSidebar", toggleSidebar);
    backdrop.addEventListener("click", closeSidebar);
    closeBtn.addEventListener("click", closeSidebar);
</script>
